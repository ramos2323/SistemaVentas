@model IEnumerable<SistemaVentas.Models.Categoria>
@{ ViewBag.Title = "Categorías"; }

<div class="ph">
    <div><div class="ph-title"><i class="bi bi-tags"></i> Categorías</div></div>
    <a href="/Categorias/Create" class="btn-p"><i class="bi bi-plus-lg"></i> Nueva</a>
</div>
<div class="card-dark">
    <table class="sv-table">
        <thead><tr><th>#</th><th>Nombre</th><th>Descripción</th><th>Acciones</th></tr></thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td style="color:var(--text3);font-size:.8rem">#@c.Id</td>
                    <td style="color:var(--text);font-weight:500">@c.Nombre</td>
                    <td style="color:var(--text3)">@c.Descripcion</td>
                    <td style="display:flex;gap:.3rem">
                        <a href="/Categorias/Edit/@c.Id" class="bi-btn"><i class="bi bi-pencil"></i></a>
                        <a href="/Categorias/Delete/@c.Id" class="bi-btn bi-btn-d"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>