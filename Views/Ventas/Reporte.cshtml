@model IEnumerable<SistemaVentas.Models.Venta>
@{ ViewBag.Title = "Reporte de Ventas"; }

<div class="ph">
    <div><div class="ph-title"><i class="bi bi-bar-chart-line"></i> Reporte de Ventas</div></div>
    <a href="/Ventas" class="btn-s"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="g4" style="margin-bottom:1.5rem">
    <div class="stat">
        <div class="stat-ico" style="background:rgba(79,142,247,.12)"><i class="bi bi-receipt" style="color:#93c5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Ventas</div><div class="stat-val" style="color:#93c5fd">@Model.Count()</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(34,197,94,.12)"><i class="bi bi-cash-stack" style="color:#4ade80;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Ingresos</div><div class="stat-val" style="color:#4ade80">$@Model.Sum(v => v.Total).ToString("N2")</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(245,158,11,.12)"><i class="bi bi-calculator" style="color:#fbbf24;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Promedio</div><div class="stat-val" style="color:#fbbf24">$@(Model.Any()?Model.Average(v=>v.Total).ToString("N2"):"0.00")</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(124,92,252,.12)"><i class="bi bi-graph-up-arrow" style="color:#c4b5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Más alta</div><div class="stat-val" style="color:#c4b5fd">$@(Model.Any()?Model.Max(v=>v.Total).ToString("N2"):"0.00")</div></div>
    </div>
</div>

<div class="card-dark">
    <table class="sv-table">
        <thead><tr><th>#</th><th>Fecha</th><th>Cliente</th><th>Productos</th><th>Total</th><th>Estado</th></tr></thead>
        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td style="color:var(--text3)">#@v.Id</td>
                    <td style="font-size:.82rem">@v.Fecha.ToString("dd/MM/yyyy")</td>
                    <td style="color:var(--text)">@v.Cliente.Nombre</td>
                    <td><span class="b-blue">@v.DetalleVentas.Count item(s)</span></td>
                    <td class="text-g fw7">$@v.Total.ToString("N2")</td>
                    <td><span class="b-green">@v.Estado</span></td>
                </tr>
            }
        </tbody>
    </table>
</div>