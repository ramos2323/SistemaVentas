@model SistemaVentas.Models.Venta
@{
    ViewBag.Title = "Nueva Venta";
    var productos = ViewBag.Productos as List<SistemaVentas.Models.Producto>;
}

<div class="ph">
    <div>
        <div class="ph-title"><i class="bi bi-cart-plus" style="font-size:1.3rem"></i> Nueva Venta</div>
        <div class="ph-sub">Selecciona cliente y productos</div>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="g2" style="align-items:start;gap:1.25rem">

        <div style="display:flex;flex-direction:column;gap:1rem">
            <div class="card-dark">
                <div class="card-dark-header"><i class="bi bi-person"></i> Datos de la Venta</div>
                <div style="padding:1.25rem" class="fd">
                    <div class="field">
                        <label>Cliente</label>
                        @Html.DropDownList("ClienteId", null, "-- Seleccione cliente --", new { @class = "fd-select" })
                    </div>
                    <div class="field">
                        <label>Observación</label>
                        @Html.TextAreaFor(m => m.Observacion, new { @class = "fd-input", rows = 2, placeholder = "Opcional..." })
                    </div>
                </div>
            </div>

            <div class="card-dark">
                <div class="card-dark-header"><i class="bi bi-receipt"></i> Resumen</div>
                <div style="padding:1.25rem">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem">
                        <span style="color:var(--text3);font-size:.85rem">Total de la venta</span>
                        <span id="total-display" style="font-family:var(--fh);font-size:1.6rem;font-weight:800;color:#4ade80">$0.00</span>
                    </div>
                    <button type="submit" class="btn-p" style="width:100%;justify-content:center;padding:.75rem">
                        <i class="bi bi-check-lg"></i> Registrar Venta
                    </button>
                    <a href="/Ventas" class="btn-s" style="width:100%;justify-content:center;padding:.75rem;margin-top:.5rem">Cancelar</a>
                </div>
            </div>
        </div>

        <div class="card-dark">
            <div class="card-dark-header"><i class="bi bi-box-seam"></i> Productos disponibles</div>
            <table class="sv-table">
                <thead><tr><th>Producto</th><th>Precio</th><th>Stock</th><th>Cantidad</th><th>Subtotal</th></tr></thead>
                <tbody>
                    @for (int i = 0; i < productos.Count; i++)
                    {
                        <tr>
                            <td style="color:var(--text)">
                                @productos[i].Nombre
                                <input type="hidden" name="ProductoIds" value="@productos[i].Id" />
                            </td>
                            <td class="text-g">$@productos[i].Precio.ToString("N2")</td>
                            <td>
                                @if (productos[i].Stock < 10)
                                {<span class="b-yellow">@productos[i].Stock</span> }
                            else
                            { <span style="color:var(--text2)">@productos[i].Stock</span>}
                            </td>
                            <td>
                                <input type="number" name="Cantidades" value="0" min="0" max="@productos[i].Stock"
                                       class="qty-input" data-precio="@productos[i].Precio"
                                       onchange="calcTotal()"
                                       style="width:75px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:.4rem .6rem;color:var(--text);font-size:.88rem;outline:none;text-align:center" />
                            </td>
                            <td class="subtotal" style="color:var(--text3);font-size:.85rem">$0.00</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
}

<style>
    .fd-select, .fd-input {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .68rem 1rem;
        color: var(--text);
        font-family: var(--fb);
        font-size: .9rem;
        outline: none;
        transition: border-color .2s;
        appearance: none;
    }

        .fd-select:focus, .fd-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79,142,247,.12);
        }
</style>
<script>
    function calcTotal() {
        var t = 0;
        document.querySelectorAll('.qty-input').forEach(function (inp) {
            var q = parseFloat(inp.value) || 0, p = parseFloat(inp.dataset.precio) || 0, s = q * p;
            t += s;
            inp.closest('tr').querySelector('.subtotal').textContent = '$' + s.toFixed(2);
        });
        document.getElementById('total-display').textContent = '$' + t.toFixed(2);
    }
</script>