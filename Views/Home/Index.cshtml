@{
    ViewBag.Title = "Dashboard";
}

<div class="ph">
    <div>
        <div class="ph-title">Dashboard</div>
        <div class="ph-sub">Bienvenido de vuelta, <strong style="color:var(--text2)">@Session["UsuarioNombre"]</strong> 👋</div>
    </div>
    <a href="/Ventas/Create" class="btn-p"><i class="bi bi-plus-lg"></i> Nueva Venta</a>
</div>

<div class="g4" style="margin-bottom:1.5rem">
    <div class="stat">
        <div class="stat-ico" style="background:rgba(79,142,247,.12)"><i class="bi bi-cart-check" style="color:#93c5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Total Ventas</div><div class="stat-val" style="color:#93c5fd">@ViewBag.TotalVentas</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(34,197,94,.12)"><i class="bi bi-cash-stack" style="color:#4ade80;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Ingresos</div><div class="stat-val" style="color:#4ade80">$@string.Format("{0:N2}", ViewBag.IngresosTotales)</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(245,158,11,.12)"><i class="bi bi-people" style="color:#fbbf24;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Clientes</div><div class="stat-val" style="color:#fbbf24">@ViewBag.TotalClientes</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(124,92,252,.12)"><i class="bi bi-box-seam" style="color:#c4b5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Productos</div><div class="stat-val" style="color:#c4b5fd">@ViewBag.TotalProductos</div></div>
    </div>
</div>

@if (ViewBag.ProductosAgotados != null && (int)ViewBag.ProductosAgotados > 0)
{
    <div class="alert-d" style="margin-bottom:1rem">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <strong>@ViewBag.ProductosAgotados producto(s) agotado(s)</strong>
        <a href="/Productos/Inventario" style="margin-left:.5rem;color:#f87171;text-decoration:underline">Ver →</a>
    </div>
}
@if (ViewBag.StockBajo != null && (int)ViewBag.StockBajo > 0)
{
    <div class="alert-w" style="margin-bottom:1.5rem">
        <i class="bi bi-exclamation-circle-fill"></i>
        <strong>@ViewBag.StockBajo producto(s) con stock bajo</strong>
        <a href="/Productos/Inventario" style="margin-left:.5rem;color:#fbbf24;text-decoration:underline">Ver →</a>
    </div>
}

<div class="g2" style="align-items:start">
    <div class="card-dark">
        <div class="card-dark-header"><span><i class="bi bi-lightning-charge"></i> Accesos Rápidos</span></div>
        <div style="padding:1rem;display:flex;flex-direction:column;gap:.5rem">
            @{
                var links = new[] {
                    new { Href="/Ventas/Create",       Icon="bi-cart-plus",      Color="#93c5fd", Bg="rgba(79,142,247,.15)",  Border="var(--accent)",  Label="Registrar Venta" },
                    new { Href="/Clientes/Create",     Icon="bi-person-plus",    Color="#4ade80", Bg="rgba(34,197,94,.15)",   Border="var(--green)",   Label="Nuevo Cliente" },
                    new { Href="/Productos/Create",    Icon="bi-box-seam",       Color="#fbbf24", Bg="rgba(245,158,11,.15)",  Border="var(--yellow)",  Label="Nuevo Producto" },
                    new { Href="/Productos/Inventario",Icon="bi-clipboard-data", Color="#67e8f9", Bg="rgba(6,182,212,.15)",   Border="#06b6d4",        Label="Ver Inventario" },
                };
            }
            @foreach (var l in links)
            {
                <a href="@l.Href" style="display:flex;align-items:center;gap:.75rem;padding:.72rem 1rem;border-radius:10px;border:1px solid var(--border);background:var(--surface2);color:var(--text2);text-decoration:none;font-size:.87rem;transition:border-color .15s,color .15s"
                   onmouseover="this.style.borderColor='@l.Border';this.style.color='var(--text)'"
                   onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text2)'">
                    <span style="width:30px;height:30px;background:@l.Bg;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="bi @l.Icon" style="color:@l.Color"></i>
                    </span>
                    @l.Label
                </a>
            }
            @if (Session["UsuarioRol"] != null && Session["UsuarioRol"].ToString() == "Admin")
            {
                <a href="/Reportes" style="display:flex;align-items:center;gap:.75rem;padding:.72rem 1rem;border-radius:10px;border:1px solid var(--border);background:var(--surface2);color:var(--text2);text-decoration:none;font-size:.87rem;transition:border-color .15s,color .15s"
                   onmouseover="this.style.borderColor='var(--accent2)';this.style.color='var(--text)'"
                   onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text2)'">
                    <span style="width:30px;height:30px;background:rgba(124,92,252,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                        <i class="bi bi-bar-chart-line" style="color:#c4b5fd"></i>
                    </span>
                    Ver Reportes
                </a>
            }
        </div>
    </div>

    <div class="card-dark">
        <div class="card-dark-header">
            <span><i class="bi bi-clock-history"></i> Últimas Ventas</span>
            <a href="/Ventas" style="font-size:.78rem;color:var(--accent)">Ver todas →</a>
        </div>
        <table class="sv-table">
            <thead><tr><th>#</th><th>Cliente</th><th>Fecha</th><th>Total</th><th>Estado</th></tr></thead>
            <tbody>
                @if (ViewBag.UltimasVentas != null)
                {
                    foreach (var v in ViewBag.UltimasVentas)
                    {
                        <tr>
                            <td><a href="/Ventas/Details/@v.Id" style="color:var(--accent);font-weight:600">#@v.Id</a></td>
                            <td style="color:var(--text)">@v.Cliente.Nombre</td>
                            <td style="font-size:.8rem">@v.Fecha.ToString("dd/MM/yy HH:mm")</td>
                            <td class="text-g fw7">$@string.Format("{0:N2}", v.Total)</td>
                            <td><span class="b-green">@v.Estado</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--text3)">Sin ventas — <a href="/Ventas/Create">¡Registra la primera!</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
