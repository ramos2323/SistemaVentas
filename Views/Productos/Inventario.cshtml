@model IEnumerable<SistemaVentas.Models.Producto>
@{ ViewBag.Title = "Inventario"; }

<div class="ph">
    <div><div class="ph-title"><i class="bi bi-clipboard-data"></i> Inventario</div><div class="ph-sub">Estado actual del stock</div></div>
    <a href="/Productos" class="btn-s"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="g4" style="margin-bottom:1.5rem">
    <div class="stat">
        <div class="stat-ico" style="background:rgba(79,142,247,.12)"><i class="bi bi-box-seam" style="color:#93c5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Total</div><div class="stat-val" style="color:#93c5fd">@Model.Count()</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(245,158,11,.12)"><i class="bi bi-exclamation-circle" style="color:#fbbf24;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Stock bajo</div><div class="stat-val" style="color:#fbbf24">@Model.Count(p => p.Stock > 0 && p.Stock < 10)</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(239,68,68,.12)"><i class="bi bi-x-circle" style="color:#f87171;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Agotados</div><div class="stat-val" style="color:#f87171">@Model.Count(p => p.Stock == 0)</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(34,197,94,.12)"><i class="bi bi-currency-dollar" style="color:#4ade80;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Valor total</div><div class="stat-val" style="color:#4ade80">$@Model.Sum(p => p.Precio * p.Stock).ToString("N2")</div></div>
    </div>
</div>

<div class="card-dark">
    <table class="sv-table">
        <thead><tr><th>Producto</th><th>Categoría</th><th>Precio</th><th>Stock</th><th>Valor</th><th>Estado</th></tr></thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td style="color:var(--text);font-weight:500">@p.Nombre</td>
                    <td><span class="b-blue">@p.Categoria.Nombre</span></td>
                    <td class="text-g">$@p.Precio.ToString("N2")</td>
                    <td style="color:var(--text)">@p.Stock</td>
                    <td>$@((p.Precio*p.Stock).ToString("N2"))</td>
                    <td>
                        @if (p.Stock == 0)
                        {<span class="b-red">Agotado</span>}
                        else if (p.Stock < 10)
                        {<span class="b-yellow">Stock bajo</span>}
                        else
                        {<span class="b-green">Disponible</span>}
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>