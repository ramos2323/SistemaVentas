@model SistemaVentas.Models.Producto
@{ ViewBag.Title = "Eliminar Producto"; }

<div class="ph">
    <div><div class="ph-title" style="color:#f87171"><i class="bi bi-trash"></i> Eliminar Producto</div></div>
    <a href="/Productos" class="btn-s"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

@if ((bool)ViewBag.TieneVentas)
{
    <div class="card-dark" style="max-width:500px;border-color:rgba(245,158,11,.3)">
        <div style="padding:1.5rem;text-align:center">
            <div style="width:60px;height:60px;background:rgba(245,158,11,.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
                <i class="bi bi-shield-exclamation" style="font-size:1.6rem;color:#fbbf24"></i>
            </div>
            <h3 style="color:#fbbf24;font-family:var(--fh);margin-bottom:.5rem">No se puede eliminar</h3>
            <p style="color:var(--text2);margin-bottom:.5rem">
                El producto <strong style="color:var(--text)">@Model.Nombre</strong> aparece en
                <span class="b-yellow">@ViewBag.TotalVentas venta(s)</span> registrada(s).
            </p>
            <p style="color:var(--text3);font-size:.85rem;margin-bottom:1.5rem">
                No se puede eliminar un producto con historial de ventas. Puedes desactivarlo en su lugar.
            </p>
            <div style="display:flex;gap:.5rem;justify-content:center">
                <a href="/Productos/Edit/@Model.Id" class="btn-p"><i class="bi bi-toggle-off"></i> Desactivar producto</a>
                <a href="/Productos" class="btn-s">Volver</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="card-dark" style="max-width:480px;border-color:rgba(239,68,68,.25)">
        <div style="padding:1.5rem;text-align:center">
            <div style="width:60px;height:60px;background:rgba(239,68,68,.1);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem">
                <i class="bi bi-exclamation-triangle" style="font-size:1.5rem;color:#f87171"></i>
            </div>
            <p style="color:var(--text2);margin-bottom:1.5rem">¿Eliminar <strong style="color:var(--text)">@Model.Nombre</strong>?</p>
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Id)
                <div style="display:flex;gap:.5rem;justify-content:center">
                    <button type="submit" class="btn-danger"><i class="bi bi-trash"></i> Sí, eliminar</button>
                    <a href="/Productos" class="btn-s">Cancelar</a>
                </div>
            }
        </div>
    </div>
}