@model SistemaVentas.Models.Venta
@{
    ViewBag.Title = "Nueva Venta";
    var productos = ViewBag.Productos as List<SistemaVentas.Models.Producto>;
}

<div class="ph">
    <div>
        <div class="ph-title"><i class="bi bi-cart-plus"></i> Nueva Venta</div>
        <div class="ph-sub">Selecciona cliente y productos</div>
    </div>
</div>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div class="g2" style="align-items:start;gap:1.25rem">

        <!-- Panel izquierdo -->
        <div style="display:flex;flex-direction:column;gap:1rem">
            <div class="card-dark">
                <div class="card-dark-header"><i class="bi bi-person"></i> Datos de la Venta</div>
                <div style="padding:1.25rem">
                    <div style="margin-bottom:1.2rem">
                        <label style="display:block;font-size:.75rem;font-weight:600;color:var(--text3);letter-spacing:.05em;text-transform:uppercase;margin-bottom:.42rem">Cliente</label>
                        @Html.DropDownList("ClienteId", null, "-- Seleccione cliente --",
                            new { style = "width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:.68rem 1rem;color:var(--text);font-size:.9rem;outline:none;appearance:none" })
                    </div>
                    <div>
                        <label style="display:block;font-size:.75rem;font-weight:600;color:var(--text3);letter-spacing:.05em;text-transform:uppercase;margin-bottom:.42rem">Observación</label>
                        @Html.TextAreaFor(m => m.Observacion,
                            new { rows = 2, placeholder = "Opcional...", style = "width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:.68rem 1rem;color:var(--text);font-size:.9rem;outline:none;resize:none" })
                    </div>
                </div>
            </div>

            <div class="card-dark">
                <div class="card-dark-header"><i class="bi bi-receipt"></i> Resumen</div>
                <div style="padding:1.25rem">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem">
                        <span style="color:var(--text3);font-size:.85rem">Productos seleccionados</span>
                        <span id="cant-seleccionados" style="color:var(--accent);font-weight:600">0</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem">
                        <span style="color:var(--text3);font-size:.85rem">Total</span>
                        <span id="total-display" style="font-family:var(--fh);font-size:1.6rem;font-weight:800;color:#4ade80">$0.00</span>
                    </div>
                    <button type="submit" class="btn-p" style="width:100%;justify-content:center;padding:.75rem">
                        <i class="bi bi-check-lg"></i> Registrar Venta
                    </button>
                    <a href="/Ventas" class="btn-s" style="width:100%;justify-content:center;padding:.75rem;margin-top:.5rem">Cancelar</a>
                </div>
            </div>
        </div>

        <!-- Panel derecho: productos con buscador -->
        <div class="card-dark">
            <div class="card-dark-header"><i class="bi bi-box-seam"></i> Productos disponibles</div>

            <!-- Buscador -->
            <div style="padding:.75rem 1rem;border-bottom:1px solid var(--border)">
                <div style="position:relative">
                    <i class="bi bi-search" style="position:absolute;left:.85rem;top:50%;transform:translateY(-50%);color:var(--text3);font-size:.88rem"></i>
                    <input type="text" id="buscar-producto"
                           placeholder="Buscar producto..."
                           oninput="filtrarProductos(this.value)"
                           style="width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:.6rem 1rem .6rem 2.4rem;color:var(--text);font-size:.88rem;outline:none;transition:border-color .2s"
                           onfocus="this.style.borderColor='var(--accent)'"
                           onblur="this.style.borderColor='var(--border)'" />
                </div>
            </div>

            <div style="max-height:420px;overflow-y:auto">
                <table class="sv-table">
                    <thead style="position:sticky;top:0;background:var(--surface);z-index:1">
                        <tr><th>Producto</th><th>Precio</th><th>Stock</th><th>Cantidad</th><th>Subtotal</th></tr>
                    </thead>
                    <tbody id="tbody-productos">
                        @for (int i = 0; i < productos.Count; i++)
                        {
                            <tr class="fila-producto" data-nombre="@productos[i].Nombre.ToLower()" data-categoria="@productos[i].Categoria.Nombre.ToLower()">
                                <td style="color:var(--text);font-weight:500">
                                    @productos[i].Nombre
                                    <input type="hidden" name="ProductoIds" value="@productos[i].Id" />
                                    <div style="font-size:.75rem;color:var(--text3)">@productos[i].Categoria.Nombre</div>
                                </td>
                                <td class="text-g" style="white-space:nowrap">$@productos[i].Precio.ToString("N2")</td>
                                <td>
                                    @if (productos[i].Stock < 10)
                                    {<span class="b-yellow">@productos[i].Stock</span> }
                                else
                                { <span style="color:var(--text2)">@productos[i].Stock</span>}
                                </td>
                                <td>
                                    <input type="number" name="Cantidades" value="0" min="0"
                                           max="@productos[i].Stock"
                                           class="qty-input"
                                           data-precio="@productos[i].Precio"
                                           onchange="calcTotal()"
                                           oninput="calcTotal()"
                                           style="width:72px;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:.38rem .5rem;color:var(--text);font-size:.88rem;outline:none;text-align:center;transition:border-color .2s"
                                           onfocus="this.style.borderColor='var(--accent)'"
                                           onblur="this.style.borderColor='var(--border)'" />
                                </td>
                                <td class="subtotal" style="color:var(--text3);font-size:.85rem;white-space:nowrap">$0.00</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div id="sin-productos" style="display:none;text-align:center;padding:2rem;color:var(--text3)">
                    <i class="bi bi-search" style="font-size:1.5rem;display:block;margin-bottom:.4rem"></i>
                    Sin productos que coincidan
                </div>
            </div>
        </div>

    </div>
}

<script>
function filtrarProductos(q) {
    q = q.toLowerCase().trim();
    const filas = document.querySelectorAll('.fila-producto');
    let visibles = 0;
    filas.forEach(function(fila) {
        const nombre = fila.dataset.nombre || '';
        const cat = fila.dataset.categoria || '';
        const mostrar = q === '' || nombre.includes(q) || cat.includes(q);
        fila.style.display = mostrar ? '' : 'none';
        if (mostrar) visibles++;
    });
    document.getElementById('sin-productos').style.display = visibles === 0 ? 'block' : 'none';
}

function calcTotal() {
    let total = 0;
    let seleccionados = 0;
    document.querySelectorAll('.qty-input').forEach(function(inp) {
        const q = parseFloat(inp.value) || 0;
        const p = parseFloat(inp.dataset.precio) || 0;
        const s = q * p;
        total += s;
        if (q > 0) seleccionados++;
        const td = inp.closest('tr').querySelector('.subtotal');
        td.textContent = '$' + s.toFixed(2);
        td.style.color = q > 0 ? '#4ade80' : 'var(--text3)';
        inp.closest('tr').style.background = q > 0 ? 'rgba(79,142,247,.05)' : '';
    });
    document.getElementById('total-display').textContent = '$' + total.toFixed(2);
    document.getElementById('cant-seleccionados').textContent = seleccionados;
}
</script>