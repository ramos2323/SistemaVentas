@model SistemaVentas.Models.Producto
@{ ViewBag.Title = "Nuevo Producto"; }

<div class="ph">
    <div><div class="ph-title"><i class="bi bi-box-seam"></i> Nuevo Producto</div></div>
    <a href="/Productos" class="btn-s"><i class="bi bi-arrow-left"></i> Volver</a>
</div>
<div class="card-dark" style="max-width:580px">
    <div style="padding:1.5rem" class="fd">
        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="field"><label>Nombre</label>@Html.TextBoxFor(m => m.Nombre, new { @class = "fd-input", placeholder = "Nombre del producto" })@Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "err" })</div>
            <div class="field"><label>Descripción</label>@Html.TextAreaFor(m => m.Descripcion, new { @class = "fd-input", rows = 2, placeholder = "Opcional" })</div>
            <div class="field-row">
                <div class="field"><label>Precio</label>@Html.TextBoxFor(m => m.Precio, new { @class = "fd-input", type = "number", step = "0.01", placeholder = "0.00" })@Html.ValidationMessageFor(m => m.Precio, "", new { @class = "err" })</div>
                <div class="field"><label>Stock</label>@Html.TextBoxFor(m => m.Stock, new { @class = "fd-input", type = "number", placeholder = "0" })@Html.ValidationMessageFor(m => m.Stock, "", new { @class = "err" })</div>
            </div>
            <div class="field"><label>Categoría</label>@Html.DropDownList("CategoriaId", null, "-- Seleccione --", new { @class = "fd-input" })@Html.ValidationMessageFor(m => m.CategoriaId, "", new { @class = "err" })</div>
            <div style="display:flex;gap:.5rem;margin-top:.5rem">
                <button type="submit" class="btn-p"><i class="bi bi-check-lg"></i> Guardar</button>
                <a href="/Productos" class="btn-s">Cancelar</a>
            </div>
        }
    </div>
</div>
<style>
    .fd-input {
        width: 100%;
        background: var(--surface2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: .68rem 1rem;
        color: var(--text);
        font-family: var(--fb);
        font-size: .9rem;
        outline: none;
        transition: border-color .2s;
        appearance: none;
    }

        .fd-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(79,142,247,.12);
        }

    .err {
        color: #f87171;
        font-size: .76rem;
        margin-top: .28rem;
        display: block;
    }
</style>
