@{ ViewBag.Title = "Reportes"; }

<div class="ph">
    <div><div class="ph-title"><i class="bi bi-bar-chart-line"></i> Reportes</div><div class="ph-sub">Exporta datos en PDF o Excel</div></div>
</div>

<div class="g4" style="margin-bottom:1.5rem">
    <div class="stat">
        <div class="stat-ico" style="background:rgba(79,142,247,.12)"><i class="bi bi-cart-check" style="color:#93c5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Ventas</div><div class="stat-val" style="color:#93c5fd">@ViewBag.TotalVentas</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(34,197,94,.12)"><i class="bi bi-cash-stack" style="color:#4ade80;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Ingresos</div><div class="stat-val" style="color:#4ade80">$@string.Format("{0:N2}", ViewBag.TotalIngresos)</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(245,158,11,.12)"><i class="bi bi-box-seam" style="color:#fbbf24;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Productos</div><div class="stat-val" style="color:#fbbf24">@ViewBag.TotalProductos</div></div>
    </div>
    <div class="stat">
        <div class="stat-ico" style="background:rgba(124,92,252,.12)"><i class="bi bi-people" style="color:#c4b5fd;font-size:1.2rem"></i></div>
        <div><div class="stat-lbl">Clientes</div><div class="stat-val" style="color:#c4b5fd">@ViewBag.TotalClientes</div></div>
    </div>
</div>

<div class="g2">
    <div class="card-dark">
        <div class="card-dark-header"><i class="bi bi-receipt"></i> Reporte de Ventas</div>
        <div style="padding:1.25rem">
            <p style="color:var(--text3);font-size:.85rem;margin-bottom:1.25rem">Listado completo de ventas con cliente, vendedor, fecha y totales.</p>
            <div style="display:flex;gap:.5rem">
                <a href="/Reportes/VentasPDF" class="btn-danger" style="flex:1;justify-content:center"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                <a href="/Reportes/VentasExcel" style="flex:1;justify-content:center;display:inline-flex;align-items:center;gap:.4rem;background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.25);border-radius:10px;padding:.58rem 1.2rem;font-size:.83rem;font-weight:600;text-decoration:none;transition:.15s" onmouseover="this.style.background='rgba(34,197,94,.25)'" onmouseout="this.style.background='rgba(34,197,94,.15)'"><i class="bi bi-file-earmark-excel"></i> Excel</a>
            </div>
        </div>
    </div>
    <div class="card-dark">
        <div class="card-dark-header"><i class="bi bi-clipboard-data"></i> Reporte de Inventario</div>
        <div style="padding:1.25rem">
            <p style="color:var(--text3);font-size:.85rem;margin-bottom:1.25rem">Inventario actual con precios, stock disponible y valor total.</p>
            <div style="display:flex;gap:.5rem">
                <a href="/Reportes/InventarioPDF" class="btn-danger" style="flex:1;justify-content:center"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                <a href="/Reportes/InventarioExcel" style="flex:1;justify-content:center;display:inline-flex;align-items:center;gap:.4rem;background:rgba(34,197,94,.15);color:#4ade80;border:1px solid rgba(34,197,94,.25);border-radius:10px;padding:.58rem 1.2rem;font-size:.83rem;font-weight:600;text-decoration:none;transition:.15s" onmouseover="this.style.background='rgba(34,197,94,.25)'" onmouseout="this.style.background='rgba(34,197,94,.15)'"><i class="bi bi-file-earmark-excel"></i> Excel</a>
            </div>
        </div>
    </div>
</div>